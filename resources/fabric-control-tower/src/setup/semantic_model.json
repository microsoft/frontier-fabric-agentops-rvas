        "partitions": [
          {
            "name": "Calendar-partition",
            "mode": "import",
            "source": {
              "type": "calculated",
              "expression": "VAR MinDate = MIN(MIN(CostSummary[date]), MIN(MIN(CapacityUsage[date]), MIN(MIN(OperationalMetrics[date]), AgentAnalytics[date]))) VAR MaxDate = MAX(MAX(CostSummary[date]), MAX(MAX(CapacityUsage[date]), MAX(MAX(OperationalMetrics[date]), AgentAnalytics[date]))) RETURN ADDCOLUMNS( CALENDAR(MinDate, MaxDate), \"Year\", YEAR([Date]), \"Quarter\", QUARTER([Date]), \"Month\", MONTH([Date]), \"MonthName\", FORMAT([Date], \"MMMM\"), \"Day\", DAY([Date]), \"WeekOfYear\", WEEKNUM([Date]), \"IsWeekend\", WEEKDAY([Date], 2) >= 6 )"
            }
          }
        ],
