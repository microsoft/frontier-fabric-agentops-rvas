              "type": "entity",
              "entityName": "gold_cost_summary",
              "schemaName": "dbo",
              "expressionSource": "DatabaseQuery"
            }
          }
        ],
        "measures": [
          {
            "name": "TotalCost",
            "expression": "SUMX(CostSummary, CostSummary[daily_cost])",
            "formatString": "$#,0.00;($#,0.00);$#,0.00",
            "lineageTag": "measure-total-cost"
          },
          {
            "name": "AvgDailyCost",
            "expression": "AVERAGEX(VALUES(Calendar[Date]), [TotalCost])",
            "formatString": "$#,0.00;($#,0.00);$#,0.00",
            "lineageTag": "measure-avg-daily-cost"
          },
          {
            "name": "CostYTD",
            "expression": "TOTALYTD([TotalCost], Calendar[Date])",
            "formatString": "$#,0.00;($#,0.00);$#,0.00",
            "lineageTag": "measure-cost-ytd"
          },
          {
            "name": "CostMoMChange",
            "expression": "VAR CurrentMonth = [TotalCost] VAR PreviousMonth = CALCULATE([TotalCost], DATEADD(Calendar[Date], -1, MONTH)) RETURN DIVIDE(CurrentMonth - PreviousMonth, PreviousMonth, 0)",
            "formatString": "0.00%",
            "lineageTag": "measure-cost-mom-change"
          },
          {
            "name": "CostRolling7Day",
            "expression": "CALCULATE([TotalCost], DATESINPERIOD(Calendar[Date], MAX(Calendar[Date]), -7, DAY))",
            "formatString": "$#,0.00;($#,0.00);$#,0.00",
            "lineageTag": "measure-cost-rolling-7day"
          }
        ]
